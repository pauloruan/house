{
  "openapi": "3.0.0",
  "info": {
    "title": "My House API",
    "description": "API para gerenciar casas, contas e participantes",
    "version": "1.0.0"
  },
  "servers": [{"url": "http://localhost:8080", "description": "Servidor local"}],
  "tags": [
    {"name": "Auth", "description": "Autenticação"},
    {"name": "User", "description": "Usuário"},
    {"name": "House", "description": "Casas"},
    {"name": "Bills", "description": "Contas"},
    {"name": "Notifications", "description": "Notificações"},
    {"name": "System", "description": "Sistema"}
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {"type": "http", "scheme": "bearer", "bearerFormat": "JWT"}
    },
    "schemas": {
      "UserProfile": {
        "type": "object",
        "properties": {
          "id": {"type": "string", "format": "uuid"},
          "name": {"type": "string"},
          "email": {"type": "string", "format": "email"},
          "profile_picture": {"type": "string", "format": "uri"},
          "pix_key": {"type": "string", "nullable": true},
          "created_at": {"type": "string", "format": "date-time"}
        }
      },
      "HouseProfile": {
        "type": "object",
        "properties": {
          "id": {"type": "string", "format": "uuid"},
          "name": {"type": "string"},
          "role": {"type": "string", "enum": ["owner", "resident"]},
          "joined_at": {"type": "string", "format": "date-time"},
          "residents_count": {"type": "integer"},
          "invite_code": {"type": "string", "nullable": true},
          "bills": {"type": "array", "items": {"$ref": "#/components/schemas/BillProfile"}}
        }
      },
      "BillProfile": {
        "type": "object",
        "properties": {
          "id": {"type": "string", "format": "uuid"},
          "title": {"type": "string"},
          "amount": {"type": "number"},
          "due_date": {"type": "string", "format": "date-time"},
          "status": {"type": "string", "enum": ["pending", "partial", "paid"]}
        }
      },
      "EventProfile": {
        "type": "object",
        "properties": {
          "id": {"type": "string", "format": "uuid"},
          "name": {"type": "string"},
          "event_date": {"type": "string", "format": "date-time"},
          "status": {"type": "string"}
        }
      },
      "MeResponse": {
        "type": "object",
        "properties": {
          "user": {"$ref": "#/components/schemas/UserProfile"},
          "house": {"$ref": "#/components/schemas/HouseProfile", "nullable": true},
          "residents": {"type": "array", "items": {"$ref": "#/components/schemas/UserProfile"}},
          "next_event": {"$ref": "#/components/schemas/EventProfile", "nullable": true}
        }
      },
      "Bill": {
        "type": "object",
        "properties": {
          "id": {"type": "string", "format": "uuid"},
          "house_id": {"type": "string"},
          "owner_id": {"type": "string"},
          "owner_name": {"type": "string"},
          "owner_pix_key": {"type": "string", "nullable": true},
          "name": {"type": "string"},
          "total_amount": {"type": "number"},
          "paid_amount": {"type": "number"},
          "type": {"type": "string", "enum": ["service", "purchase"]},
          "status": {"type": "string", "enum": ["pending", "partial", "paid"]},
          "due_date": {"type": "string", "format": "date-time"},
          "created_at": {"type": "string", "format": "date-time"},
          "paid_by": {"type": "array", "items": {"type": "string"}},
          "residents": {"type": "array", "items": {"$ref": "#/components/schemas/ResidentInfo"}}
        }
      },
      "ResidentInfo": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "profile_picture": {"type": "string"},
          "selected": {"type": "boolean"}
        }
      },
      "Notification": {
        "type": "object",
        "properties": {
          "id": {"type": "string", "format": "uuid"},
          "house_id": {"type": "string"},
          "creator_id": {"type": "string"},
          "title": {"type": "string"},
          "text": {"type": "string"},
          "created_at": {"type": "string", "format": "date-time"}
        }
      }
    }
  },
  "paths": {
    "/health": {
      "get": {"tags": ["System"], "summary": "Health check", "responses": {"200": {"description": "OK"}}}
    },
    "/greeting": {
      "get": {"tags": ["System"], "summary": "Saudação", "responses": {"200": {"description": "OK"}}}
    },
    "/auth/google/login": {
      "get": {"tags": ["Auth"], "summary": "Login Google", "responses": {"302": {"description": "Redirect"}}}
    },
    "/auth/google/callback": {
      "get": {"tags": ["Auth"], "summary": "Callback Google", "parameters": [
        {"name": "code", "in": "query", "required": true, "schema": {"type": "string"}},
        {"name": "state", "in": "query", "schema": {"type": "string"}}
      ], "responses": {"200": {"description": "Token JWT"}}}
    },
    "/me": {
      "get": {"tags": ["User"], "summary": "Perfil do usuário", "security": [{"bearerAuth": []}],
        "responses": {"200": {"description": "Perfil", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/MeResponse"}}}}, "401": {"description": "Não autenticado"}}}
    },
    "/users": {
      "get": {"tags": ["User"], "summary": "Listar moradores da casa", "security": [{"bearerAuth": []}],
        "responses": {"200": {"description": "Lista", "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/UserProfile"}}}}}}},
      "put": {"tags": ["User"], "summary": "Atualizar usuário", "security": [{"bearerAuth": []}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "properties": {"pix_key": {"type": "string"}}, "required": ["pix_key"]}}}},
        "responses": {"200": {"description": "Atualizado"}, "400": {"description": "Dados inválidos"}}},
      "delete": {"tags": ["User"], "summary": "Deletar usuário", "security": [{"bearerAuth": []}],
        "responses": {"204": {"description": "Deletado"}}}
    },
    "/house": {
      "get": {"tags": ["House"], "summary": "Casa do usuário", "security": [{"bearerAuth": []}],
        "responses": {"200": {"description": "OK"}, "404": {"description": "Sem casa"}}},
      "post": {"tags": ["House"], "summary": "Criar casa", "security": [{"bearerAuth": []}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "properties": {"name": {"type": "string"}}, "required": ["name"]}}}},
        "responses": {"201": {"description": "Criada"}, "400": {"description": "Dados inválidos"}}},
      "put": {"tags": ["House"], "summary": "Atualizar casa", "security": [{"bearerAuth": []}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "properties": {"name": {"type": "string"}}, "required": ["name"]}}}},
        "responses": {"200": {"description": "Atualizada"}, "403": {"description": "Sem permissão"}}},
      "patch": {"tags": ["House"], "summary": "Atualizar casa (parcial)", "security": [{"bearerAuth": []}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "properties": {"name": {"type": "string"}}, "required": ["name"]}}}},
        "responses": {"200": {"description": "Atualizada"}}},
      "delete": {"tags": ["House"], "summary": "Deletar casa", "security": [{"bearerAuth": []}],
        "responses": {"204": {"description": "Deletada"}, "403": {"description": "Sem permissão"}}}
    },
    "/house/leave": {
      "post": {"tags": ["House"], "summary": "Sair da casa", "security": [{"bearerAuth": []}],
        "responses": {"204": {"description": "Saiu"}, "404": {"description": "Sem casa"}}}
    },
    "/house/regenerate-invite-code": {
      "post": {"tags": ["House"], "summary": "Regenerar código de convite", "security": [{"bearerAuth": []}],
        "responses": {"200": {"description": "Novo código"}, "403": {"description": "Sem permissão"}}}
    },
    "/house/join-with-invite-code": {
      "post": {"tags": ["House"], "summary": "Entrar na casa com código", "security": [{"bearerAuth": []}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "properties": {"invite_code": {"type": "string"}}, "required": ["invite_code"]}}}},
        "responses": {"200": {"description": "Entrou"}, "400": {"description": "Código inválido"}}}
    },
    "/notifications": {
      "get": {"tags": ["Notifications"], "summary": "Listar notificações", "security": [{"bearerAuth": []}],
        "responses": {"200": {"description": "Lista", "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/Notification"}}}}}}}
    },
    "/bills": {
      "get": {"tags": ["Bills"], "summary": "Listar contas", "security": [{"bearerAuth": []}],
        "responses": {"200": {"description": "Lista", "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/Bill"}}}}}}},
      "post": {"tags": ["Bills"], "summary": "Criar conta", "security": [{"bearerAuth": []}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "properties": {
          "name": {"type": "string"}, "type": {"type": "string", "enum": ["service", "purchase"]},
          "total_amount": {"type": "number"}, "due_date": {"type": "string", "format": "date"},
          "resident_ids": {"type": "array", "items": {"type": "string"}}
        }, "required": ["name", "type", "total_amount", "due_date"]}}}},
        "responses": {"201": {"description": "Criada"}}},
      "put": {"tags": ["Bills"], "summary": "Atualizar conta", "security": [{"bearerAuth": []}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "properties": {
          "id": {"type": "string"}, "name": {"type": "string"}, "type": {"type": "string"},
          "total_amount": {"type": "number"}, "due_date": {"type": "string", "format": "date"},
          "status": {"type": "string"}, "resident_ids": {"type": "array", "items": {"type": "string"}}
        }, "required": ["id"]}}}},
        "responses": {"200": {"description": "Atualizada"}}},
      "delete": {"tags": ["Bills"], "summary": "Deletar conta", "security": [{"bearerAuth": []}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "properties": {"id": {"type": "string"}}, "required": ["id"]}}}},
        "responses": {"204": {"description": "Deletada"}, "409": {"description": "Possui pagamentos"}}}
    },
    "/bills/pay": {
      "post": {"tags": ["Bills"], "summary": "Informar pagamento", "security": [{"bearerAuth": []}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "properties": {"id": {"type": "string"}}, "required": ["id"]}}}},
        "responses": {"200": {"description": "Pago"}}}
    }
  }
}
